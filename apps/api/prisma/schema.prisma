// apps/api/prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Environment {
  id           Int       @id @default(autoincrement())
  name         String    @unique
  version      String    @default("0.0.0")
  customerType String?   @map("customer_type")
  status       String    @default("onboarding")
  signedDate   DateTime? @map("signed_date") @db.Date
  goLiveDate   DateTime? @map("go_live_date") @db.Date
  openRequests Int       @default(0) @map("open_requests")
  comment      String?
  updatedAt    DateTime  @updatedAt
  createdAt    DateTime  @default(now())
}

model DailyEnvironmentVolume {
  id            Int      @id @default(autoincrement())
  customerId    String   @map("customer_id") @db.VarChar(64)
  environmentId String   @map("environment_id") @db.VarChar(64)
  volume        Decimal  @db.Decimal(20, 2)
  depositCount  Int      @default(0) @map("deposit_count")
  date          DateTime @db.Date
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([customerId, environmentId, date])
  @@index([customerId, date])
  @@map("daily_environment_volume")
}
