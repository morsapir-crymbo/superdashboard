// apps/api/prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Environment {
  id           Int       @id @default(autoincrement())
  name         String    @unique
  version      String    @default("0.0.0")
  customerType String?   @map("customer_type")
  status       String    @default("onboarding")
  signedDate   DateTime? @map("signed_date") @db.Date
  goLiveDate   DateTime? @map("go_live_date") @db.Date
  openRequests Int       @default(0) @map("open_requests")
  comment      String?
  updatedAt    DateTime  @updatedAt
  createdAt    DateTime  @default(now())
}

model User {
  id         String    @id @default(cuid())
  email      String    @unique
  googleId   String?   @unique @map("google_id")
  name       String?
  picture    String?
  role       String    @default("user")
  lastSeenAt DateTime? @map("last_seen_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

model DailyEnvironmentVolume {
  id            Int      @id @default(autoincrement())
  customerId    String   @map("customer_id") @db.VarChar(64)
  environmentId String   @map("environment_id") @db.VarChar(64)
  volume        Decimal  @db.Decimal(20, 2)
  depositCount  Int      @default(0) @map("deposit_count")
  date          DateTime @db.Date
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([customerId, environmentId, date])
  @@index([customerId, date])
  @@map("daily_environment_volume")
}

model DailyMetrics {
  id            Int      @id @default(autoincrement())
  customerId    String   @map("customer_id") @db.VarChar(64)
  date          DateTime @db.Date

  // ═══════════════════════════════════════════════════════════
  // DEPOSITS - CRYPTO
  // ═══════════════════════════════════════════════════════════
  cryptoDepositVolume Decimal @default(0) @map("crypto_deposit_volume") @db.Decimal(20, 2)
  cryptoDepositCount  Int     @default(0) @map("crypto_deposit_count")
  cryptoDepositFees   Decimal @default(0) @map("crypto_deposit_fees") @db.Decimal(20, 2)

  // ═══════════════════════════════════════════════════════════
  // DEPOSITS - FIAT
  // ═══════════════════════════════════════════════════════════
  fiatDepositVolume Decimal @default(0) @map("fiat_deposit_volume") @db.Decimal(20, 2)
  fiatDepositCount  Int     @default(0) @map("fiat_deposit_count")
  fiatDepositFees   Decimal @default(0) @map("fiat_deposit_fees") @db.Decimal(20, 2)

  // ═══════════════════════════════════════════════════════════
  // WITHDRAWALS - CRYPTO
  // ═══════════════════════════════════════════════════════════
  cryptoWithdrawalVolume Decimal @default(0) @map("crypto_withdrawal_volume") @db.Decimal(20, 2)
  cryptoWithdrawalCount  Int     @default(0) @map("crypto_withdrawal_count")
  cryptoWithdrawalFees   Decimal @default(0) @map("crypto_withdrawal_fees") @db.Decimal(20, 2)

  // ═══════════════════════════════════════════════════════════
  // WITHDRAWALS - FIAT
  // ═══════════════════════════════════════════════════════════
  fiatWithdrawalVolume Decimal @default(0) @map("fiat_withdrawal_volume") @db.Decimal(20, 2)
  fiatWithdrawalCount  Int     @default(0) @map("fiat_withdrawal_count")
  fiatWithdrawalFees   Decimal @default(0) @map("fiat_withdrawal_fees") @db.Decimal(20, 2)

  // ═══════════════════════════════════════════════════════════
  // TRANSFERS (tracked separately, not counted as volume)
  // ═══════════════════════════════════════════════════════════
  transferVolume Decimal @default(0) @map("transfer_volume") @db.Decimal(20, 2)
  transferCount  Int     @default(0) @map("transfer_count")
  transferFees   Decimal @default(0) @map("transfer_fees") @db.Decimal(20, 2)

  // ═══════════════════════════════════════════════════════════
  // TRADES
  // ═══════════════════════════════════════════════════════════
  tradeVolume Decimal @default(0) @map("trade_volume") @db.Decimal(20, 2)
  tradeCount  Int     @default(0) @map("trade_count")
  tradeFees   Decimal @default(0) @map("trade_fees") @db.Decimal(20, 2)

  // ═══════════════════════════════════════════════════════════
  // KYT EVENTS
  // ═══════════════════════════════════════════════════════════
  kytEventCount Int @default(0) @map("kyt_event_count")

  // ═══════════════════════════════════════════════════════════
  // METADATA
  // ═══════════════════════════════════════════════════════════
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([customerId, date])
  @@index([customerId, date])
  @@map("daily_metrics")
}

/// Checkpoints for incremental API sync (per customer, per environment, per source).
/// Only updated after a batch is successfully processed and written to daily_metrics.
model SyncCheckpoint {
  id             Int      @id @default(autoincrement())
  customerId     String   @map("customer_id") @db.VarChar(64)
  environmentId  String   @map("environment_id") @db.VarChar(64)
  source         String   @db.VarChar(32) // deposits | transfers | withdrawals | trades
  lastId         BigInt   @map("last_id")
  lastUpdatedAt  DateTime? @map("last_updated_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([customerId, environmentId, source])
  @@index([customerId, environmentId])
  @@map("sync_checkpoints")
}

/// Marks that a customer/environment has completed the DB bootstrap
/// and is allowed to switch to API-only incremental sync.
model SyncBootstrapState {
  id            Int      @id @default(autoincrement())
  customerId    String   @map("customer_id") @db.VarChar(64)
  environmentId String   @map("environment_id") @db.VarChar(64)
  method        String   @default("db-bootstrap") @db.VarChar(32)
  completedAt   DateTime @default(now()) @map("completed_at")

  @@unique([customerId, environmentId])
  @@map("sync_bootstrap_state")
}

/// Post-bootstrap source records tracked for incremental reconciliation.
/// Unique by customer/environment/source/source_id so updated rows can be
/// compared against their previous stored state without double counting.
model SyncSourceRecord {
  id              Int      @id @default(autoincrement())
  customerId      String   @map("customer_id") @db.VarChar(64)
  environmentId   String   @map("environment_id") @db.VarChar(64)
  source          String   @db.VarChar(32)
  sourceKey       String   @map("source_key") @db.VarChar(255)
  eventDate       DateTime @map("event_date") @db.Date
  sourceUpdatedAt DateTime? @map("source_updated_at")
  status          String?  @db.VarChar(64)
  isIncluded      Boolean  @default(false) @map("is_included")
  isCrypto        Boolean? @map("is_crypto")
  amountUsd       Decimal  @default(0) @map("amount_usd") @db.Decimal(20, 2)
  feeUsd          Decimal  @default(0) @map("fee_usd") @db.Decimal(20, 2)
  kytEvent        Boolean  @default(false) @map("kyt_event")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([customerId, environmentId, source, sourceKey])
  @@index([customerId, eventDate])
  @@map("sync_source_records")
}
