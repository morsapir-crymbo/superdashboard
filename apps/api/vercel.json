{
  "framework": null,
  "buildCommand": "npx prisma generate && npx prisma migrate deploy && npm run build",
  "functions": {
    "api/index.ts": {
      "runtime": "@vercel/node@5.3.24",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index",                    
      "methods": ["GET","POST","PUT","PATCH","DELETE","OPTIONS"] 
    }
  ],
  "crons": [
    {
      "path": "/cron/snapshot",
      "schedule": "0 0 * * *"
    }
  ]
}
